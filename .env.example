# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/

# Nombre de la base de datos
DB_NAME=biblioteca

# JWT Secret (cambiar por uno seguro en producción)
JWT_SECRET=cambiar_este_secreto_por_uno_muy_largo_y_seguro

# Contraseña del admin inicial
ADMIN_PASSWORD=admin123

# Puerto del servidor local
PORT=3000

# Entorno (development o production)
NODE_ENV=development

# Cloudinary (opcional, para subir imágenes)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
